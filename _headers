/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; frame-src https://highlight.xyz https://mint.highlight.xyz; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://mint.highlight.xyz https://fonts.googleapis.com https://fonts.gstatic.com;
